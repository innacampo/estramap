# ──────────────────────────────────────────────────────────
# Server mode (production / self-hosted):
#   Keys stay server-side only. Run with `npm start`.
# ──────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
PORT=3001

# ──────────────────────────────────────────────────────────
# Direct mode (lovable.ai / static hosting without server):
#   Set these VITE_ vars so the browser talks to Supabase
#   and Google directly. Keys will be in the JS bundle.
# ──────────────────────────────────────────────────────────
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key
# VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
